{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: Benchmark Release",
            "type": "dotnet",
            "request": "launch",
            "preLaunchTask": "build Release",
            "projectPath": "${workspaceFolder}/benchmarks/Okojo.Benchmarks/Okojo.Benchmarks.csproj"
        }

    ],
    "tasks": [
        {
            "taskName": "build Debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/benchmarks/Okojo.Benchmarks/Okojo.Benchmarks.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "taskName": "build Release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/dotnetcore-test.csproj",
                "-c",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        }        ,
        {
            "taskName": "run Debug",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "${workspaceFolder}/dotnetcore-test.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "taskName": "run Release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "${workspaceFolder}/dotnetcore-test.csproj",
                "-c",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        }        
    ]
}

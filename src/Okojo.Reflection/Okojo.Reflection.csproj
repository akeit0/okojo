<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14</LangVersion>
        <IsAotCompatible>false</IsAotCompatible>
        <IsPackable>true</IsPackable>
        <PackageId>Okojo.Reflection</PackageId>
        <Description>Reflection-based CLR interop extensions for Okojo runtimes.</Description>
        <PackageTags>javascript;ecmascript;reflection;interop;clr;dotnet</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Okojo\Okojo.csproj"/>
    </ItemGroup>
    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
